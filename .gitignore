# ── Compiled binaries & build output ──────────────────────────────
# Go build artifacts (the two service binaries plus any ad-hoc builds)
api-server
ws-worker
/bin/
/dist/
*.exe
*.exe~
*.dll
*.so
*.dylib
*.test
*.out

# ── Go workspace / module local state ─────────────────────────────
# Keep go.work (checked in for reproducible local dev), ignore its lockfile
go.work.sum
# Vendored deps (we rely on the module cache, not vendoring)
/vendor/

# ── Test & coverage output ────────────────────────────────────────
*.cover
coverage.*
coverage.out
profile.out
*.prof

# ── Environment & secrets ─────────────────────────────────────────
.env
.env.*
!.env.example
*.local

# ── Database / Redis local data volumes ───────────────────────────
# In case docker volumes are ever bind-mounted into the repo
/data/
mysql_data/
redis_data/
*.sqlite
*.db

# ── Logs ──────────────────────────────────────────────────────────
*.log
logs/

# ── Editor / IDE ──────────────────────────────────────────────────
.idea/
.vscode/
*.swp
*.swo
*~

# ── OS cruft ──────────────────────────────────────────────────────
.DS_Store
Thumbs.db
